rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Training progress: one doc per user at users/{uid}/data/progress
    // Fields: sessions (map of sessionId -> { done, rpe?, note? }), updatedAt
    match /users/{userId}/data/progress {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
